#!/usr/bin/env bash
# SessionStart hook — inject constitution skill into every session

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Read constitution skill
constitution_content=$(cat "${PLUGIN_ROOT}/skills/using-my-workflow/SKILL.md" 2>/dev/null || echo "Error reading constitution skill")

# Escape for JSON embedding
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

constitution_escaped=$(escape_for_json "$constitution_content")
session_context="<workflow-constitution>\nYou are working with a developer who follows a structured workflow (spec-first, plan-review, TDD, serial-review).\n\nBelow is the full content of the 'ironflow:using-my-workflow' skill — your workflow constitution. For all other skills, use the 'Skill' tool:\n\n${constitution_escaped}\n</workflow-constitution>"

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
fi

exit 0
